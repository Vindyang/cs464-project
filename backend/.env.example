# PostgreSQL connection string from Supabase (Transaction pooler mode).
# Supabase dashboard → Project Settings → Database → Connection string → URI
# Use the "Transaction" pooler (port 6543) with ?pgbouncer=true
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true

# OAuth2 client credentials JSON (Web application type, downloaded from GCP Console).
# GCP Console → APIs & Services → Credentials → Create Credentials → OAuth 2.0 Client ID
# Credential type must be "Web application" (not Desktop app).
# Add authorized redirect URI: http://localhost:8080/api/oauth/gdrive/callback
GDRIVE_OAUTH_CREDENTIALS_FILE=/path/to/gdrive-oauth-credentials.json

# Redirect URI registered in GCP Console for the OAuth callback.
GDRIVE_OAUTH_REDIRECT_URI=http://localhost:8080/api/oauth/gdrive/callback

# ID of the Google Drive folder where shards will be stored.
# Found in the folder URL: https://drive.google.com/drive/folders/<FOLDER_ID>
GDRIVE_FOLDER_ID=your_folder_id_here

# Frontend base URL — used to redirect back after OAuth completes.
FRONTEND_URL=http://localhost:3000
