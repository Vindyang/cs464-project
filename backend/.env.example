# OAuth2 client credentials JSON (Desktop app type, downloaded from GCP Console).
# GCP Console → APIs & Services → Credentials → Create Credentials → OAuth 2.0 Client ID
GDRIVE_OAUTH_CREDENTIALS_FILE=/path/to/gdrive-oauth-credentials.json

# Token file — generated by running: go run ./cmd/gdrive-auth/main.go
GDRIVE_TOKEN_FILE=/path/to/gdrive-token.json

# ID of the Google Drive folder where shards will be stored.
# Found in the folder URL: https://drive.google.com/drive/folders/<FOLDER_ID>
GDRIVE_FOLDER_ID=your_folder_id_here
